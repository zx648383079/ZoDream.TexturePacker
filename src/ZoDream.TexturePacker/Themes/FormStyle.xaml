<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="using:ZoDream.TexturePacker.Controls">

    <Thickness x:Key="TextBoxTopHeaderMargin">0,12,0,2</Thickness>
    <Thickness x:Key="ComboBoxTopHeaderMargin">0,12,0,2</Thickness>
    <Thickness x:Key="PasswordBoxTopHeaderMargin">0,12,0,2</Thickness>
    <Style x:Key="LinkTb" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Padding" Value="8,2" />
    </Style>
    <Style x:Key="LockBtn" TargetType="ctl:ToggleIcon">
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Padding" Value="2,2,2,6" />
    </Style>
    <Style x:Key="RestoreBtn" TargetType="Button">
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Content" Value="&#xE777;" />
        <Setter Property="MinWidth" Value="20" />
        <Setter Property="ToolTipService.ToolTip" Value="重置属性" />
        <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
    </Style>
    <Style x:Name="HeaderIcon" TargetType="FontIcon">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Name="HeaderStamp" TargetType="FontIcon">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="8" />
        <Setter Property="FontSize" Value="{StaticResource MetaFontSize}" />
        <Setter Property="Foreground" Value="{ThemeResource SecondaryTextBrush}" />
    </Style>

    <Style x:Name="InlineHeaderTb" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{ThemeResource SecondaryTextBrush}" />
    </Style>
    <Style x:Name="InlineTextTb" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{ThemeResource BodyTextBrush}" />
    </Style>

    <Style x:Name="IconBtn" TargetType="Button">
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
    </Style>

    <Style x:Name="MetaLabelStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="FontSize" Value="{StaticResource MetaFontSize}" />
        <Setter Property="Foreground" Value="{ThemeResource SecondaryTextBrush}" />
    </Style>
    <Style x:Name="HeaderLabelStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="FontWeight" Value="Black" />
        <Setter Property="Foreground" Value="{ThemeResource BodyTextBrush}" />
    </Style>
</ResourceDictionary>
